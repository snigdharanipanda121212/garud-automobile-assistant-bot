{
  "entities": {
    "Script": {
      "title": "Script",
      "description": "A commercial script for Garud Automobiles",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the script" },
        "content": { "type": "string", "description": "The script content in Odiya" },
        "englishTranslation": { "type": "string", "description": "English translation" },
        "status": { "type": "string", "enum": ["draft", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "content", "createdAt", "authorId"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "viewer"] },
        "photoURL": { "type": "string" }
      },
      "required": ["displayName", "email", "role"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "A vehicle in the Garud EVCO range",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "string" },
        "model": { "type": "string" },
        "range": { "type": "string" },
        "batteryWarranty": { "type": "string" },
        "vehicleWarranty": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "model", "range", "batteryWarranty", "vehicleWarranty"]
    },
    "Quotation": {
      "title": "Quotation",
      "description": "A customer quotation request",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "financeNeeded": { "type": "boolean" },
        "vehicleId": { "type": "string" },
        "vehicleName": { "type": "string" },
        "vehicleModel": { "type": "string" },
        "vehiclePrice": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "address", "vehicleId", "status", "createdAt"]
    },
    "TestDrive": {
      "title": "TestDrive",
      "description": "A customer test drive booking",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "vehicleId": { "type": "string" },
        "vehicleName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "date", "time", "vehicleId", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/scripts/{scriptId}": {
      "schema": "Script",
      "description": "Collection of scripts"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of users"
    },
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Collection of vehicles"
    },
    "/quotations/{quotationId}": {
      "schema": "Quotation",
      "description": "Collection of quotation requests"
    },
    "/test_drives/{testDriveId}": {
      "schema": "TestDrive",
      "description": "Collection of test drive bookings"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of customer reviews"
    }
  }
}
